{
    "name": "waaseyaa/ssr",
    "description": "Server-side rendering with Twig templates for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../typed-data"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../foundation"
        }
    ],
    "require": {
        "php": ">=8.4",
        "symfony/html-sanitizer": "^8.0",
        "waaseyaa/api": "^0.1.0-alpha.150",
        "waaseyaa/access": "^0.1.0-alpha.150",
        "waaseyaa/cache": "^0.1.0-alpha.150",
        "waaseyaa/config": "^0.1.0-alpha.150",
        "waaseyaa/entity": "^0.1.0-alpha.150",
        "waaseyaa/field": "^0.1.0-alpha.150",
        "waaseyaa/foundation": "^0.1.0-alpha.150",
        "waaseyaa/routing": "^0.1.0-alpha.150",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\SSR\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\SSR\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\SSR\\ThemeServiceProvider",
                "Waaseyaa\\SSR\\SsrServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
