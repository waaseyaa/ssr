{
    "name": "aurora/ssr",
    "description": "Server-side rendering with Twig templates for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../field"},
        {"type": "path", "url": "../access"}
    ],
    "require": {
        "php": ">=8.3",
        "aurora/entity": "@dev",
        "aurora/routing": "@dev",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\SSR\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\SSR\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
