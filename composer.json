{
    "name": "waaseyaa/ssr",
    "description": "Server-side rendering with Twig templates for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../routing"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../field"},
        {"type": "path", "url": "../access"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/access": "@dev",
        "waaseyaa/cache": "@dev",
        "waaseyaa/entity": "@dev",
        "waaseyaa/field": "@dev",
        "waaseyaa/routing": "@dev",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\SSR\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\SSR\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": ["Waaseyaa\\SSR\\ThemeServiceProvider", "Waaseyaa\\SSR\\SsrServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
